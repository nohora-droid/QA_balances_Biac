# Credenciales Google Sheets (elige una opción)

# Opción A: API Key (sheet debe estar compartido como "cualquiera con el enlace")
# GOOGLE_API_KEY=AIzaSy...

# Opción B: Service Account (sheet privado — pega el JSON completo en una sola línea)
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# Credenciales app Olibia (para Playwright)
# OLIBIA_EMAIL=usuario@bia.com.co
# OLIBIA_PASSWORD=contraseña
